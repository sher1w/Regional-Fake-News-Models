etadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T11:28:01.884664Z","iopub.execute_input":"2026-03-30T11:28:01.884888Z","iopub.status.idle":"2026-03-30T11:28:01.902626Z","shell.execute_reply.started":"2026-03-30T11:28:01.884866Z","shell.execute_reply":"2026-03-30T11:28:01.902070Z"}},"outputs":[{"name":"stdout","text":"Device: cuda\nConfig: batch=32, epochs=5, lr=2e-05, dropout=0.1\n","output_type":"stream"}],"execution_count":5},{"id":"cell-03-data","cell_type":"code","source":"# ── CELL 3: Load & clean data ─────────────────────────────────\n# Minimal cleaning — don't over-strip Hindi text\ndef convert_label(x):\n    return 1 if 'fake' in str(x).lower() else 0\n\ndef clean_text(text):\n    text = str(text)\n    text = re.sub(r'http\\S+', '', text)                     # remove URLs\n    text = re.sub(r'[^\\w\\s\\u0900-\\u097F]', ' ', text)      # keep Hindi + word chars\n    text = re.sub(r'\\s+', ' ', text)\n    return text.strip()\n\ndef prepare_df(path):\n    df = pd.read_csv(path).copy()\n    df['label'] = df['Labels Set'].apply(convert_label)\n    df['text']  = df['Post'].astype(str).apply(clean_text)\n    df = df.drop_duplicates(subset='text')\n    df = df[df['text'].str.split().str.len() > 5]\n    return df[['text', 'label']].reset_index(drop=True)\n\ntrain_df = prepare_df(TRAIN_PATH)\nvalid_df = prepare_df(VALID_PATH)\ntest_df  = prepare_df(TEST_PATH)\n\nprint('Dataset breakdown:')\nprint('-' * 60)\nfor name, df in [('Train', train_df), ('Valid', valid_df), ('Test', test_df)]:\n    total = len(df)\n    fake  = int(df['label'].sum())\n    real  = total - fake\n    print(f'{name:6s}  total={total:5d}  fake={fake:4d} ({fake/total*100:.1f}%)  non-fake={real:4d} ({real/total*100:.1f}%)')\nprint('-' * 60)\n\n# Class weight for imbalanced data (20% fake, 80% non-fake)\nn_fake    = int(train_df['label'].sum())\nn_nonfake = len(train_df) - n_fake\nweight_fake    = len(train_df) / (2 * n_fake)\nweight_nonfake = len(train_df) / (2 * n_nonfake)\nclass_weights = torch.tensor([weight_nonfake, weight_fake], dtype=torch.float).to(device)\nprint(f'Class weights: non-fake={weight_nonfake:.3f}, fake={weight_fake:.3f}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T11:28:01.903522Z","iopub.execute_input":"2026-03-30T11:28:01.903831Z","iopub.status.idle":"2026-03-30T11:28:02.174757Z","shell.execute_reply.started":"2026-03-30T11:28:01.903809Z","shell.execute_reply":"2026-03-30T11:28:02.174158Z"}},"outputs":[{"name":"stdout","text":"Dataset breakdown:\n------------------------------------------------------------\nTrain   total= 5622  fake=1127 (20.0%)  non-fake=4495 (80.0%)\nValid   total=  802  fake= 157 (19.6%)  non-fake= 645 (80.4%)\nTest    total= 1627  fake= 330 (20.3%)  non-fake=1297 (79.7%)\n------------------------------------------------------------\nClass weights: non-fake=0.625, fake=2.494\n","output_type":"stream"}],"execution_count":6},{"id":"cell-04-dataset","cell_type":"code","source":"# ── CELL 4: Dataset & DataLoader ──────────────────────────────\ntokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n\nclass HindiNewsDataset(Dataset):\n    def __init__(self, df, tokenizer, max_len):\n        self.texts  = df['text'].tolist()\n        self.labels = df['label'].tolist()\n        self.tok    = tokenizer\n        self.max_len = max_len\n\n    def __len__(self):\n        return len(self.texts)\n\n    def __getitem__(self, idx):\n        enc = self.tok(\n            self.texts[idx],\n            max_length=self.max_len,\n            padding='max_length',\n            truncation=True,\n            return_tensors='pt',\n        )\n        return {\n            'input_ids':      enc['input_ids'].squeeze(0),\n            'attention_mask': enc['attention_mask'].squeeze(0),\n            'label':          torch.tensor(self.labels[idx], dtype=torch.long),\n        }\n\ntrain_ds = HindiNewsDataset(train_df, tokenizer, MAX_LEN)\nvalid_ds = HindiNewsDataset(valid_df, tokenizer, MAX_LEN)\ntest_ds  = HindiNewsDataset(test_df,  tokenizer, MAX_LEN)\n\ntrain_loader = DataLoader(train_ds, batch_size=BATCH_SIZE, shuffle=True,  num_workers=2, pin_memory=True)\nvalid_loader = DataLoader(valid_ds, batch_size=BATCH_SIZE, shuffle=False, num_workers=2, pin_memory=True)\ntest_loader  = DataLoader(test_ds,  batch_size=BATCH_SIZE, shuffle=False, num_workers=2, pin_memory=True)\n\nprint(f'Loaders ready — train={len(train_loader)} batches, val={len(valid_loader)}, test={len(test_loader)}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T11:28:02.176233Z","iopub.execute_input":"2026-03-30T11:28:02.176447Z","iopub.status.idle":"2026-03-30T11:28:03.743714Z","shell.execute_reply.started":"2026-03-30T11:28:02.176426Z","shell.execute_reply":"2026-03-30T11:28:03.742943Z"}},"outputs":[{"name":"stderr","text":"Warning: You are sending unauthenticated requests to the HF Hub. Please set a HF_TOKEN to enable higher rate limits and faster downloads.\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"config.json:   0%|          | 0.00/625 [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"8bcaaf34b729419a93c6048a9d1c9eb8"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"tokenizer_config.json:   0%|          | 0.00/49.0 [00:00<?, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"b5ccd74f68be4a91af05ac04fd201fd5"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"vocab.txt: 0.00B [00:00, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"bc7233f39d734c3fa79e06bc378c559b"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"tokenizer.json: 0.00B [00:00, ?B/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"ffab67fc859b4422ad527d078c210a0e"}},"metadata":{}},{"name":"stdout","text":"Loaders ready — train=176 batches, val=26, test=51\n","output_type":"stream"}],"execution_count":7},{"id":"cell-05-model","cell_type":"code","source":"# ── CELL 5: Model — mBERT + 2×2 MLP head (matches paper) ─────\n#\n# Paper Section 3.2.1:\n#   \"The default Softmax classification head was removed in favour of\n#    a multi layer perceptron (MLP). The MLP consists of 2 hidden layers,\n#    each having 2 neurons with a ReLU activation function.\"\n#\n# Architecture:\n#   [CLS] hidden (768-dim) → Dropout(0.1) → Linear(768→2) → ReLU\n#                          → Linear(2→2)   → ReLU → Linear(2→2) [logits]\n\nclass MBertWithMLPHead(nn.Module):\n    def __init__(self, model_name, dropout=0.1):\n        super().__init__()\n        self.bert    = AutoModel.from_pretrained(model_name)\n        hidden_size  = self.bert.config.hidden_size  # 768 for mBERT\n\n        # Paper's 2×2 MLP: 2 hidden layers, 2 nodes each, ReLU\n        self.mlp = nn.Sequential(\n            nn.Dropout(dropout),\n            nn.Linear(hidden_size, 2),\n            nn.ReLU(),\n            nn.Linear(2, 2),\n            nn.ReLU(),\n        )\n        # Final classifier to num_labels=2\n        self.classifier = nn.Linear(2, 2)\n\n    def forward(self, input_ids, attention_mask):\n        outputs = self.bert(input_ids=input_ids, attention_mask=attention_mask)\n        cls_output = outputs.last_hidden_state[:, 0, :]   # [CLS] token\n        logits = self.classifier(self.mlp(cls_output))\n        return logits\n\n    def get_probs(self, input_ids, attention_mask):\n        logits = self.forward(input_ids, attention_mask)\n        return F.softmax(logits, dim=-1)\n\nmodel = MBertWithMLPHead(MODEL_NAME, dropout=DROPOUT).to(device)\n\ntotal_params     = sum(p.numel() for p in model.parameters())\ntrainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\nprint(f'Total params:     {total_params:,}')\nprint(f'Trainable params: {trainable_params:,}')","metadata":{"trusted":true,"execution":{"i