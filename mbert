meters(), lr=LR, weight_decay=0.01)\n\ntotal_steps  = len(train_loader) * EPOCHS\nwarmup_steps = int(total_steps * WARMUP_FRAC)\n\nscheduler = get_linear_schedule_with_warmup(\n    optimizer,\n    num_warmup_steps=warmup_steps,\n    num_training_steps=total_steps,\n)\n\n# Weighted loss — handles 80/20 class imbalance\ncriterion = nn.CrossEntropyLoss(weight=class_weights)\n\nprint(f'Total steps: {total_steps}, Warmup steps: {warmup_steps}')\nprint(f'Optimizer: AdamW lr={LR}, wd=0.01')\nprint(f'Loss: CrossEntropyLoss with class weights')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T11:28:06.953833Z","iopub.execute_input":"2026-03-30T11:28:06.954233Z","iopub.status.idle":"2026-03-30T11:28:06.960152Z","shell.execute_reply.started":"2026-03-30T11:28:06.954206Z","shell.execute_reply":"2026-03-30T11:28:06.959470Z"}},"outputs":[{"name":"stdout","text":"Total steps: 880, Warmup steps: 88\nOptimizer: AdamW lr=2e-05, wd=0.01\nLoss: CrossEntropyLoss with class weights\n","output_type":"stream"}],"execution_count":9},{"id":"cell-07-eval-fn","cell_type":"code","source":"# ── CELL 7: Evaluation function ───────────────────────────────\ndef evaluate(model, loader, criterion, device, return_probs=False):\n    model.eval()\n    all_preds, all_labels, all_probs = [], [], []\n    total_loss = 0.0\n\n    with torch.no_grad():\n        for batch in loader:\n            input_ids      = batch['input_ids'].to(device)\n            attention_mask = batch['attention_mask'].to(device)\n            labels         = batch['label'].to(device)\n\n            logits = model(input_ids, attention_mask)\n            loss   = criterion(logits, labels)\n            total_loss += loss.item()\n\n            probs = F.softmax(logits, dim=-1).cpu().numpy()\n            preds = probs.argmax(axis=1)\n\n            all_probs.extend(probs)\n            all_preds.extend(preds)\n            all_labels.extend(labels.cpu().numpy())\n\n    all_preds  = np.array(all_preds)\n    all_labels = np.array(all_labels)\n    all_probs  = np.array(all_probs)\n\n    metrics = {\n        'loss':      total_loss / len(loader),\n        'accuracy':  accuracy_score(all_labels, all_preds),\n        'precision': precision_score(all_labels, all_preds, pos_label=1, zero_division=0),\n        'recall':    recall_score(all_labels, all_preds, pos_label=1, zero_division=0),\n        'f1':        f1_score(all_labels, all_preds, pos_label=1, zero_division=0),\n        'macro_f1':  f1_score(all_labels, all_preds, average='macro', zero_division=0),\n        'mcc':       matthews_corrcoef(all_labels, all_preds),\n    }\n\n    if return_probs:\n        return metrics, all_probs, all_labels\n    return metrics\n\nprint('Evaluation function ready.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T11:28:06.961067Z","iopub.execute_input":"2026-03-30T11:28:06.961404Z","iopub.status.idle":"2026-03-30T11:28:07.033109Z","shell.execute_reply.started":"2026-03-30T11:28:06.961382Z","shell.execute_reply":"2026-03-30T11:28:07.032466Z"}},"outputs":[{"name":"stdout","text":"Evaluation function ready.\n","output_type":"stream"}],"execution_count":10},{"id":"cell-08-train","cell_type":"code","source":"# ── CELL 8: Training loop ─────────────────────────────────────\n# Best checkpoint saved on VAL MCC — most informative metric for imbalanced data\n\nhistory = {'train_loss': [], 'val_loss': [], 'train_f1': [], 'val_f1': [], 'val_mcc': []}\nbest_val_mcc  = -1.0\nbest_epoch    = -1\n\nprint(f'Starting training: {EPOCHS} epochs, batch={BATCH_SIZE}, lr={LR}')\nprint('=' * 75)\n\nfor epoch in range(1, EPOCHS + 1):\n    # ── Train ──\n    model.train()\n    train_loss = 0.0\n    train_preds, train_labels = [], []\n\n    for step, batch in enumerate(train_loader):\n        input_ids      = batch['input_ids'].to(device)\n        attention_mask = batch['attention_mask'].to(device)\n        labels         = batch['label'].to(device)\n\n        optimizer.zero_grad()\n        logits =