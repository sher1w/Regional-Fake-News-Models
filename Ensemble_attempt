n state_dict.items():\n        new_k = k.replace('LayerNorm.gamma', 'LayerNorm.weight') \\\n                 .replace('LayerNorm.beta',  'LayerNorm.bias')\n        fixed[new_k] = v\n    # ─────────────────────────────────────────────────────────\n\n    missing, unexpected = model.load_state_dict(fixed, strict=False)\n    # Only report truly missing keys (not the gamma/beta ones we just fixed)\n    real_missing = [k for k in missing if 'LayerNorm' not in k]\n    if real_missing: print(f'  Missing keys: {real_missing[:3]}')\n    return model.eval().to(device)\n\nprint('Loading MuRIL...')\nmurl_model = load_murl(CONFIG['murl_model_dir'], CONFIG['device'])\nprint('✅ MuRIL loaded')\n\n# Quick sanity check — MuRIL should output varied probabilities\nprint('\\nSanity check — MuRIL on 2 samples:')\nwith torch.no_grad():\n    test_sample = murl_tok(\n        [train_texts[0], train_texts[1]],\n        max_length=128, padding='max_length',\n        truncation=True, return_tensors='pt'\n    ).to(CONFIG['device'])\n    logits = murl_model(**test_sample).logits\n    probs  = torch.softmax(logits.float(), dim=-1)[:,1]\n    print(f'  Sample 1 P(fake): {probs[0].item():.4f}  (label: {train_labels[0]})')\n    print(f'  Sample 2 P(fake): {probs[1].item():.4f}  (label: {train_labels[1]})')\n    print('  ✅ MuRIL working!' if probs.max().item() > 0.01 else '  ❌ MuRIL still broken — check weights')\n\nif torch.cuda.is_available():\n    used  = torch.cuda.memory_allocated()/1e9\n    total = torch.cuda.get_device_properties(0).total_memory/1e9\n    print(f'\\n  GPU after both models: {used:.1f} / {total:.1f} GB')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-22T10:35:09.687681Z","iopub.execute_input":"2026-03-22T10:35:09.688532Z","iopub.status.idle":"2026-03-22T10:35:19.905733Z","shell.execute_reply.started":"2026-03-22T10:35:09.688502Z","shell.execute_reply":"2026-03-22T10:35:19.904927Z"}},"outputs":[{"name":"stdout","text":"Loading MuRIL...\n✅ MuRIL loaded\n\nSanity check — MuRIL on 2 samples:\n  Sample 1 P(fake): 0.0691  (label: 0)\n  Sample 2 P(fake): 0.0656  (label: 0)\n  ✅ MuRIL working!\n\n  GPU after both models: 1.6 / 15.6 GB\n","output_type":"stream"}],"execution_count":9},{"cell_type":"code","source":"def load_mbert(model_dir, device):\n    \"\"\"Load mBERT — saved as standard HuggingFace format, no gamma/beta fix needed.\"\"\"\n    model = AutoModelForSequenceClassification.from_pretrained(\n        model_dir,\n        num_labels=2,\n        problem_type='single_label_classification',\n    )\n    return model.eval().to(device)\n\nprint('Loading mBERT...')\nmbert_model = load_mbert(CONFIG['mbert_model_dir'], CONFIG['device'])\nprint('✅ mBERT loaded')\n\n# Sanity check\nprint('\\nSanity check — mBERT on 2 samples:')\nwith torch.no_grad():\n    test_sample = mbert_tok(\n        [train_texts[0], train_texts[1]],\n        max_length=256, padding='max_length',\n        truncation=True, return_tensors='pt'\n    ).to(CONFIG['device'])\n    logits = mbert_model(**test_sample).logits\n    probs  = torch.softmax(logits.float(), dim=-1)[:,1]\n    print(f'  Sample 1 P(fake): {probs[0].item():.4f}  (label: {train_labels[0]})')\n    print(f'  Sample 2 P(fake): {probs[1].item():.4f}  (label: {train_labels[1]})')\n    print('  ✅ mBERT working!' if probs.max().item() > 0.01 else '  ❌ mBERT broken — check weights')\n\nif torch.cuda.is_available():\n    used  = torch.cuda.memory_allocated()/1e9\n    total = torch.cuda.get_device_properties(0).total_memory/1e9\n    print(f'  GPU after all 3 models: {used:.1f} / {total:.1f} GB')","metadata":{},"outputs":[],"execution_count":null},{"cell_type":"code","source":"@torch.no_grad()\ndef get_fake_probs(model, loader):\n    \"\"\"Returns P(fake) for each sample — shape (N,)\"\"\"\n    all_probs = []\n    device = next(model.parameters()).device\n    for batch in loader:\n        ids  = batch['input_ids'].to(device)\n        mask = batch['attention_mask'].to(device)\n        logits = model(input_ids=ids, attention_mask=mask).logits\n        probs  = torch.softmax(logits.float(), dim=-1)[:,1]\n        all_probs.append(probs.cpu().numpy())\n    return np.concatenate(all_probs)\n\n# mBERT needs max_length=256 (same as how it was trained)\ndef make_loader_mbert(texts, labels, config):\n    cfg_256 = {**config, 'max_length': 256}\n    return make_loader(texts, labels, mbert_tok, cfg_256)\n\nsarvam_probs, murl_probs, mbert_probs = {}, {}, {}\nfor split, (texts, labels, _) in splits.items():\n    print(f'Inferencing {split} ({len(texts)} samples)...')\n    sarvam_probs[split] = get_fake_probs(sarvam_model, make_loader(texts, labels, sarvam_tok, CONFIG))\n    murl_probs[split]   = get_fake_probs(murl_model,   make_loader(texts, labels, murl_tok,   CONFIG))\n    mbert_probs[split]  = get_fake_probs(mbert_model,  make_loader_mbert(texts, labels, CONFIG))\n    print(f'  Sarvam mean P(fake): {sarvam_probs[split].mean():.3f}')\n    print(f'  MuRIL  mean P(fake): {murl_probs[split].mean():.3f}')\n    print(f'  mBERT  mean P(fake): {mbert_probs[split].mean():.3f}')\n    print()\nprint('✅ Inference complete for all 3 models')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-22T10:35:29.135905Z","iopub.execute_input":"2026-03-22T10:35:29.136217Z","iopub.status.idle":"2026-03-22T10:45:39.653575Z","shell.execute_reply.started":"2026-03-22T10:35:29.136190Z","shell.execute_reply":"2026-03-22T10:45:39.652883Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ══════════════════════════════════════════════════════════════════════\n#   LATE FUSION — Stacked Logistic Regression Meta-Learner\n#   Models: Sarvam-1 + MuRIL + mBERT (6 probability features)\n#\n#   Why meta-learner on validation is correct:\n#     • All 3 base models were trained on the TRAIN split only\n#     • Validation is held-out → no data leakage into the meta-learner\n#     • Test is never touched until final evaluation\n# ══════════════════════════════════════════════════════════════════════\n\nfrom sklearn.linear_model import LogisticRegression\n\nthr = CONFIG['threshold']\n\nprint(\"=\" * 65)\nprint(\"  LATE FUSION: 3-model stacked meta-learner\")\nprint(\"=\" * 65)\n\n# ── Step 1: Build 6-feature meta-matrices ────────────────────────────\n# Features: [Sarvam P(nf), Sarvam P(f), MuRIL P(nf), MuRIL P(f), mBERT P(nf), mBERT P(f)]\nprint(\"\\n[1/4] Building meta-features ...\")\nmeta_features = {}\nfor split in splits:\n    s_p = sarvam_probs[split]\n    m_p = murl_probs[split]\n    b_p = mbert_probs[split]\n    meta_features[split] = np.column_stack([\n        1 - s_p, s_p,     # Sarvam\n        1 - m_p, m_p,     # MuRIL\n        1 - b_p, b_p,     # mBERT\n    ])\n    print(f\"  {split:<6}: meta-feature matrix shape = {meta_features[split].shape}  (6 features)\")\n\n# ── Step 2: Train meta-learner on VALIDATION set ──────────────────────\nprint(\"\\n[2/4] Training meta-learner on validation set ...\")\nclass_weights_dict = {\n    0: CONFIG['class_weights'][0].item(),\n    1: CONFIG['class_weights'][1].item(),\n}\nprint(f\"  Class weights: Non-Fake={class_weights_dict[0]:.4f}, Fake={class_weights_dict[1]:.4f}\")\n\nmeta_learner = LogisticRegression(\n    class_weight  = class_weights_dict,\n    max_iter      = 2000,\n    solver        = 'lbfgs',\n    random_state  = 42,\n    C             = 1.0,\n    fit_intercept = True,\n)\ny_valid_arr = np.array(valid_labels)\nmeta_learner.fit(meta_features['valid'], y_valid_arr)\n\ncoef = meta_learner.coef_[0]\nprint(f\"  Learned weights (what the meta-learner trusts most):\")\nprint(f\"    Sarvam P(fake)  : {coef[1]:+.3f}\")\nprint(f\"    MuRIL  P(fake)  : {coef[3]:+.3f}\")\nprint(f\"    mBERT  P(fake)  : {coef[5]:+.3f}\")\n\n# ── Step 3: Calibrate threshold on validation F1 ──────────────────────\nprint(\"\\n[3/4] Calibrating decision threshold ...\")\nval_meta_probs = meta_learner.predict_proba(meta_features['valid'])[:, 1]\n\nbest_f1, best_thr = 0.0, 0.5\nfor candidate_thr in np.arange(0.20, 0.81, 0.01):\n    preds_cand = (val_meta_probs >= candidate_thr).astype(int)\n    f1_cand    = f1_score(y_valid_arr, preds_cand, zero_division=0)\n    if f1_cand > best_f1:\n        best_f1  = f1_cand\n        best_thr = round(float(candidate_thr), 2)\n\nprint(f\"  Best threshold : {best_thr}  (Binary F1 on valid = {best_f1:.4f})\")\nfusion_thr = best_thr\n\n# ── Step 4: Generate predictions on all splits ────────────────────────\nprint(\"\\n[4/4] Generating predictions ...\")\nens_preds, ens_probs = {}, {}\nfor split in splits:\n    proba = meta_learner.predict_proba(meta_features[split])[:, 1]\n    ens_probs[split] = proba\n    ens_preds[split] = (proba >= fusion_thr).astype(int)\n    n_fake = ens_preds[split].sum()\n    print(f\"  {split:<6}: {n_fake} fake / {len(ens_preds[split])} total  ({n_fake/len(ens_preds[split])*100:.1f}%)\")\n\nprint(\"\\n✅ Late Fusion complete\")\nprint(f\"   Models    : Sarvam-1 + MuRIL + mBERT\")\nprint(f\"   Features  : 6 (2 probs × 3 models)\")\nprint(f\"   Threshold : {fusion_thr} (calibrated on validation Binary F1)\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-22T10:46:00.731132Z","iopub.execute_input":"2026-03-22T10:46:00.731759Z","iopub.status.idle":"2026-03-22T10:46:00.765448Z","shell.execute_reply.started":"2026-03-22T10:46:00.731728Z","shell.execute_reply":"2026-03-22T10:46:00.764726Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 📊 CONFUSION MATRICES - Train, Valid, Test for ALL Models","metadata":{}},{"cell_type":"code","source":"CELL_LABELS = [['TN','FP'],['FN','TP']]\n\nfig, axes = plt.subplots(3, 4, figsize=(24, 17))\nfig.suptitle(\n    'Confusion Matrices — All Models × All Splits\\n'\n    'Sarvam-1  |  MuRIL  |  mBERT  |  Late Fusion',\n    fontsize=16, fontweight='bold'\n)\n\nsplit_keys  = ['train', 'valid', 'test']\nsplit_names = ['Train', 'Valid', 'Test']\n\n_thr = fusion_thr\nmodel_cols = [\n    ('Sarvam-1',    {s:(sarvam_probs[s]>=_thr).astype(int) for s i