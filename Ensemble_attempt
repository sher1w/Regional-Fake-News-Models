0),\n            'label'         : torch.tensor(self.labels[idx], dtype=torch.long),\n        }\n\ndef make_loader(texts, labels, tokenizer, cfg):\n    return DataLoader(\n        FakeNewsDataset(texts, labels, tokenizer, cfg['max_length']),\n        batch_size=cfg['batch_size'], shuffle=False,\n        num_workers=0, pin_memory=False\n    )\nprint('✅ Dataset ready')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-22T10:34:18.376057Z","iopub.execute_input":"2026-03-22T10:34:18.376733Z","iopub.status.idle":"2026-03-22T10:34:18.383502Z","shell.execute_reply.started":"2026-03-22T10:34:18.376704Z","shell.execute_reply":"2026-03-22T10:34:18.382779Z"}},"outputs":[{"name":"stdout","text":"✅ Dataset ready\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"print('Loading tokenizers...')\n\nsarvam_tok = AutoTokenizer.from_pretrained(CONFIG['sarvam_base_model'], trust_remote_code=True)\nif sarvam_tok.pad_token is None:\n    sarvam_tok.pad_token    = sarvam_tok.eos_token\n    sarvam_tok.pad_token_id = sarvam_tok.eos_token_id\n    print(f'  Sarvam pad token set to: \"{sarvam_tok.eos_token}\"')\n\nmurl_tok  = BertTokenizer.from_pretrained(CONFIG['murl_model_dir'])\nmbert_tok = AutoTokenizer.from_pretrained(CONFIG['mbert_model_dir'])  # mBERT uses standard HF tokenizer\n\nprint(f'  Sarvam vocab : {sarvam_tok.vocab_size:,}')\nprint(f'  MuRIL  vocab : {murl_tok.vocab_size:,}')\nprint(f'  mBERT  vocab : {mbert_tok.vocab_size:,}')\nprint('✅ Tokenizers ready')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-22T10:34:23.958781Z","iopub.execute_input":"2026-03-22T10:34:23.959505Z","iopub.status.idle":"2026-03-22T10:34:27.617943Z","shell.execute_reply.started":"2026-03-22T10:34:23.959475Z","shell.execute_reply":"2026-03-22T10:34:27.617107Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"torch.cuda.empty_cache()\ngc.collect()\n\ndef load_sarvam(checkpoint_path, base_model_name, tokenizer):\n    wi