 textcoords='offset points', ha='center',\n                        fontsize=9, color=color)\n    ax.set_title(mname, fontsize=12, fontweight='bold')\n    ax.set_xticks(x); ax.set_xticklabels(split_names)\n    ax.set_ylim(0, 1.08); ax.grid(True, alpha=0.3)\n    ax.legend(fontsize=8)\n    ax.spines['top'].set_visible(False); ax.spines['right'].set_visible(False)\n\nplt.tight_layout()\nplt.savefig('/kaggle/working/training_curves.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint('✅ Saved → /kaggle/working/training_curves.png')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-22T10:46:40.678971Z","iopub.execute_input":"2026-03-22T10:46:40.679277Z","iopub.status.idle":"2026-03-22T10:46:42.757216Z","shell.execute_reply.started":"2026-03-22T10:46:40.679253Z","shell.execute_reply":"2026-03-22T10:46:42.756615Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 🎯 EXAMPLES - True Positives, True Negatives, False Positives, False Negatives","metadata":{}},{"cell_type":"code","source":"def show_examples(split_key, split_name, n=3):\n    \"\"\"Show examples for TP, TN, FP, FN with full details\"\"\"\n    texts, true_labels, orig_labels = splits[split_key]\n    true_labels = np.array(true_labels)\n    preds       = np.array(ens_preds[split_key])\n    orig_labels = np.array(orig_labels)\n\n    cases = [\n        ('✅ TRUE POSITIVE  — Fake correctly caught',        (true_labels==1)&(preds==1)),\n        ('✅ TRUE NEGATIVE  — Not-fake correctly ignored',   (true_labels==0)&(preds==0)),\n        ('❌ FALSE POSITIVE — Not-fake wrongly flagged',     (true_labels==0)&(preds==1)),\n        ('❌ FALSE NEGATIVE — Fake post missed',             (true_labels==1)&(preds==0)),\n    ]\n    print(f'\\n{\"═\"*70}')\n    print(f'  EXAMPLES — {split_name} Set (Late Fusion Ensemble)')\n    print(f'  Class Weights: Not-Fake={CONFIG[\"class_weights\"][0]:.4f}, Fake={CONFIG[\"class_weights\"][1]:.4f}')\n    print(f'{\"═\"*70}')\n    for case_name, mask in 