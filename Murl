plit()) < 6:\n                continue\n            p, t = int(pred), int(true)\n            if   t == 1 and p == 1 and len(tp_texts) < 3: tp_texts.append(text)\n            elif t == 0 and p == 0 and len(tn_texts) < 3: tn_texts.append(text)\n            elif t == 0 and p == 1 and len(fp_texts) < 3: fp_texts.append(text)\n            elif t == 1 and p == 0 and len(fn_texts) < 3: fn_texts.append(text)\n\nfor category, samples in [\n    (\"✅  TRUE  POSITIVE — correctly caught FAKE\",     tp_texts),\n    (\"✅  TRUE  NEGATIVE — correctly passed NON-FAKE\", tn_texts),\n    (\"❌  FALSE POSITIVE — NON-FAKE wrongly flagged\",  fp_texts),\n    (\"❌  FALSE NEGATIVE — FAKE missed as NON-FAKE\",   fn_texts),\n]:\n    print(f\"\\n── {category} ──\")\n    for s in samples:\n        print(f\"   • {s[:150]}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T07:57:01.352321Z","iopub.execute_input":"2026-04-19T07:57:01.352599Z","iopub.status.idle":"2026-04-19T07:57:23.853896Z","shell.execute_reply.started":"2026-04-19T07:57:01.352575Z","shell.execute_reply":"2026-04-19T07:57:23.852958Z"}},"outputs":[{"name":"stdout","text":"\n── ✅  TRUE  POSITIVE — correctly caught FAKE ──\n   • अंडरवर्ल्ड डॉन छोटा राजन के भाई को बीजेपी द्वारा टिकट मिला है ।\n   • हैदराबाद बीजेपी विधायक राजा सिंह की बहन माया देवी ने इस्लाम स्वीकार कर लिया । उन्होंने कहा कि भारत एक लोकतांत्रिक देश है जहां धर्म चुनना हमारा व्यक्ति\n   • दाऊद इब्राहिम और उसकी पत्नि की कोरोना संक्रमण से मौत\n\n── ✅  TRUE  NEGATIVE — correctly passed NON-FAKE ──\n   • पटना BMP कैंप में पुरुष और महिला कांस्टेबल ने गोली मारकर की खुदकुशी जांच में जुटी पुलिस की रिपोर्ट\n   • RT इन पंचर छापों को कोन समझाए कि उनके रोजगार में कमी का कारण मोदी नहीं ट्यूब लैस टायर है\n   • पश्चिम बंगाल में फिर हुई माओवादियों की वापसी हाल ही में हुई घटनाएं इसका प्रमाण है\n\n── ❌  FALSE POSITIVE — NON-FAKE wrongly flagged ──\n   • कोई भी कांग्रेसी ऊंची छत पर रेलवे लाइन पर ऊंची बिल्डिंग पर एकांत जगह पर कुए के पास दिखाई दे तुरंत पुलिस को सूचित करें विलुप्त होती हुई प्रजातियो को बच\n   • मोदी देशद्रोही चोर की औलाद चीन के हाथों देश बेच देगी यह चोर लुटेरा अंग्रेज की नाजायज संतान\n   • कश्मीर के लोगों पर हो रहे ज़ुल्म के खिलाफ आवाज उठाइए ।\n\n── ❌  FALSE NEGATIVE — FAKE missed as NON-FAKE ──\n   • कीस की को रोजगार चाहिए फिर नहीं कहना रोजगार नहीं मिलता है 20 करोड को रोजगार दे दिया है वह भी मात्र 6 साँल में चार साल अभी बाकी है और हर साल दो करोड़ र\n   • कमलनाथ के राज में 100 में 100यूनिट बिजली मिल रही थी अब आए चोर शिवराज जो बिजली के बिलों को 500से 1000 तक कर दिया\n   • BMC की अपील अगले सात दिनों तक गरम पानी का सेवन करें\n","output_type":"stream"}],"execution_count":16},{"id":"709675a5-3266-46f2-bfeb-054d80b5debd","cell_type":"markdown","source":"## 10 · Save Ensemble Probabilities","metadata":{}},{"id":"122657f7-319d-419a-a7c8-09255117e800","cell_type":"code","source":"# ============================================================\n# CELL 17 — Soft probabilities + sample IDs for ensemble / fusion\n# ============================================================\ndef get_probs_and_ids(loader):\n    \"\"\"Returns softmax probabilities (N, 2) and sample IDs (N,).\"\"\"\n    model.eval()\n    all_probs, all_ids = [], []\n    with torch.no_grad():\n        for batch in loader:\n            ids  = batch[\"input_ids\"].to(device)\n            mask = batch[\"attention_mask\"].to(device)\n            logits = model(input_ids=ids, attention_mask=mask).logits\n            probs  = F.softmax(logits, dim=1).cpu().numpy()\n            all_probs.extend(probs)\n            # ── NEW: collect sample IDs ──\n            all_ids.extend(batch[\"sample_id\"].numpy())\n    return np.array(all_probs), np.array(all_ids)\n\n\nos.makedirs(PROBS_DIR, exist_ok=True)\n\ntrain_probs, train_prob_ids = get_probs_and_ids(train_loader)\nvalid_probs, valid_prob_ids = get_probs_and_ids(valid_loader)\ntest_probs,  test_prob_ids  = get_probs_and_ids(test_loader)\n\n# Probabilities — shape (N, 2)\nnp.save(f\"{PROBS_DIR}/muril_train_probs.npy\", train_probs)\nnp.save(f\"{PROBS_DIR}/muril_valid_probs.npy\", valid_probs)\nnp.save(f\"{PROBS_DIR}/muril_test_probs.npy\",  test_probs)\n\n# True labels — shape (N,)\nnp.save(f\"{PROBS_DIR}/train_labels.npy\", np.array(train_labels))\nnp.save(f\"{PROBS_DIR}/valid_labels.npy\", np.array(val_labels))\nnp.save(f\"{PROBS_DIR}/test_labels.npy\",  np.array(test_labels))\n\n# ── NEW: Sample IDs — shape (N,) ─────────────────────────────────────────\n# Each value is the original CSV row index of that sample.\n# Use np.intersect1d(sarvam_test_ids, muril_test_ids) in the ensemble\n# script to get the articles that both models processed.\nnp.save(f\"{PROBS_DIR}/muril_train_ids.npy\", train_prob_ids)\nnp.save(f\"{PROBS_DIR}/muril_valid_ids.npy\", valid_prob_ids)\nnp.save(f\"{PROBS_DIR}/muril_test_ids.npy\",  test_prob_ids)\n\nprint(f\"✓ Saved to '{PROBS_DIR}/'\")\nprint(f\"  muril_train_probs.npy  : {train_probs.shape}\")\nprint(f\"  muril_valid_probs.npy  : {valid_probs.shape}\")\nprint(f\"  muril_test_probs.npy   : {test_probs.shape}\")\nprint(f\"  muril_train_ids.npy    : {train_prob_ids.shape}   ← use these for ensemble alignment\")\nprint(f\"  muril_valid_ids.npy    : {valid_prob_ids.shape}\")\nprint(f\"  muril_test_ids.npy     : {test_prob_ids.shape}\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T07:57:23.855318Z","iopub.execute_input":"2026-04-19T07:57:23.855611Z","iopub.status.idle":"2026-04-19T07:59:14.696294Z","shell.execute_reply.started":"2026-04-19T07:57:23.855575Z","shell.execute_reply":"2026-04-19T07:59:14.695535Z"}},"outputs":[{"name":"stdout","text":"✓ Saved to 'ensemble_probs/'\n  muril_train_probs.npy  : (5622, 2)\n  muril_valid_probs.npy  : (802, 2)\n  muril_test_probs.npy   : (1627, 2)\n  muril_train_ids.npy    : (5622,)   ← use these for ensemble alignment\n  muril_valid_ids.npy    : (802,)\n  muril_test_ids.npy     : (1627,)\n","output_type":"stream"}],"execution_count":17},{"id":"b04ee169-5c82-4bcb-b86d-b3a160146976","cell_type":